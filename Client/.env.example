# Backend API URL (Vite proxy handles /api in dev, set full URL for production)
# For development: http://localhost:5001/api
# For production: https://mentormind-v3-0-s.onrender.com/api
VITE_API_URL=http://localhost:5001/api

# Socket.io URL
# IMPORTANT: Vercel does NOT support WebSocket upgrade proxying through rewrites.
# The Socket.IO client must connect DIRECTLY to the Render backend.
# For development: http://localhost:5001
# For production: https://mentormind-v3-0-s.onrender.com
# NOTE: Also set this env var in Vercel project dashboard's Environment Variables.
VITE_SOCKET_URL=http://localhost:5001
